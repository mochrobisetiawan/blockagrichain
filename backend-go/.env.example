# Salin ke .env (lokal saja). Di AWS gunakan AWS Secrets Manager (lihat di bawah).
PORT=8080

# === AWS Secrets Manager (disarankan di AWS — tanpa .env) ===
# Set AWS_SECRET_ID ke nama/ARN secret berisi JSON key->value, mis:
#   { "DATABASE_URL": "...", "JWT_KEY": "...", "S3_BUCKET": "..." }
# Nilai dari secret MENIMPA variabel di bawah. Pakai IAM role (GetSecretValue).
AWS_SECRET_ID=
AWS_REGION=ap-southeast-1

# RDBMS off-chain = SQL Server (sesuai DPPL). Format DSN go-mssqldb.
# Untuk dev lokal saja; di produksi pindahkan ke Secrets Manager (DATABASE_URL).
DATABASE_URL=sqlserver://sa:Blockagri_Strong!Pass1@localhost:1433?database=blockagri&encrypt=disable

JWT_KEY=ganti-rahasia-ini-di-produksi-minimal-32-karakter
JWT_ISSUER=BlockAgriChain
JWT_AUDIENCE=BlockAgriChain
JWT_EXPIRY_MINUTES=480

CORS_ORIGINS=http://localhost:5173

# Object storage off-chain = Amazon S3 (sesuai DPPL) — foto bukti panen/serah terima/profil.
# File diunggah klien via presigned PUT; hanya URL ke SQL Server & hash SHA-256 ke ledger.
# Di EC2: cukup S3_BUCKET + IAM role (kredensial otomatis). Kosongkan untuk pakai URL manual.
S3_BUCKET=
S3_REGION=ap-southeast-1
# Opsional: endpoint kustom (MinIO), mis. http://minio:9000 (pakai path-style)
S3_ENDPOINT=
# Opsional: override base URL publik object (mis. CloudFront)
S3_PUBLIC_BASE_URL=

FABRIC_CHANNEL=blockagri
FABRIC_CHAINCODE=blockagri
FABRIC_CRYPTO_PATH=../fabric/organizations

# Endpoint peer (lokal compose). Di Fargate ganti ke nama AWS Cloud Map, mis:
#   FABRIC_PETANI_PEER=peer0.petani.blockagri.id:7051
FABRIC_PETANI_PEER=localhost:7051
FABRIC_BULOG_PEER=localhost:8051
FABRIC_KEMENTAN_PEER=localhost:9051
FABRIC_KEMENKEU_PEER=localhost:10051
FABRIC_PIHC_PEER=localhost:11051
