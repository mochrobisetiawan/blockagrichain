{
  "info": {
    "name": "BlockAgriChain API",
    "description": "Koleksi uji BlockAgriChain. Auth Bearer {{token}} dipasang di level collection -> SEMUA request mewarisi otomatis. Request publik (status & login) di-override 'No Auth'. Set variabel: baseUrl, harvestChainId, iotKey.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "auth": {
    "type": "bearer",
    "bearer": [{ "key": "token", "value": "{{token}}", "type": "string" }]
  },
  "variable": [
    { "key": "baseUrl", "value": "https://blockagrichain.digitalisasi-pi.com" },
    { "key": "username", "value": "budi" },
    { "key": "password", "value": "password123" },
    { "key": "harvestChainId", "value": "HRV-0001" },
    { "key": "deviceId", "value": "ESP32CAM-01" },
    { "key": "iotKey", "value": "" },
    { "key": "token", "value": "" }
  ],
  "item": [
    {
      "name": "1. Status Jaringan (publik)",
      "request": {
        "auth": { "type": "noauth" },
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/api/public/network",
          "host": ["{{baseUrl}}"],
          "path": ["api", "public", "network"]
        }
      }
    },
    {
      "name": "2. Login (ambil token)",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "var j = pm.response.json();",
              "if (j && j.token) { pm.collectionVariables.set('token', j.token); }"
            ]
          }
        }
      ],
      "request": {
        "auth": { "type": "noauth" },
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"username\": \"{{username}}\",\n  \"password\": \"{{password}}\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/auth/login",
          "host": ["{{baseUrl}}"],
          "path": ["api", "auth", "login"]
        }
      }
    },
    {
      "name": "3. Daftar Panen (cari harvestChainId)",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/api/harvests",
          "host": ["{{baseUrl}}"],
          "path": ["api", "harvests"]
        },
        "description": "Mewarisi Bearer {{token}} dari collection. Lihat field 'harvestChainId' (mis. HRV-0001)."
      }
    },
    {
      "name": "4. IoT — Kirim Foto Timbangan (OCR)",
      "request": {
        "method": "POST",
        "header": [
          { "key": "X-Device-Id", "value": "{{deviceId}}" },
          { "key": "X-IoT-Key", "value": "{{iotKey}}", "disabled": true }
        ],
        "body": {
          "mode": "formdata",
          "formdata": [
            { "key": "harvestChainId", "value": "{{harvestChainId}}", "type": "text" },
            { "key": "deviceId", "value": "{{deviceId}}", "type": "text" },
            { "key": "image", "type": "file", "src": "" },
            { "key": "pileImage", "type": "file", "src": "", "disabled": true }
          ]
        },
        "url": {
          "raw": "{{baseUrl}}/api/iot/weight",
          "host": ["{{baseUrl}}"],
          "path": ["api", "iot", "weight"]
        },
        "description": "Mewarisi Bearer {{token}} dari collection. Field 'image' bertipe File (pilih foto display timbangan). Alternatif perangkat: aktifkan header X-IoT-Key. JANGAN set Content-Type manual; kirim SATU field 'image'."
      }
    },
    {
      "name": "5. IoT (Value) — Kirim Berat Langsung",
      "request": {
        "method": "POST",
        "header": [
          { "key": "X-Device-Id", "value": "{{deviceId}}" },
          { "key": "X-IoT-Key", "value": "{{iotKey}}", "disabled": true }
        ],
        "body": {
          "mode": "formdata",
          "formdata": [
            { "key": "harvestChainId", "value": "{{harvestChainId}}", "type": "text" },
            { "key": "deviceId", "value": "{{deviceId}}", "type": "text" },
            { "key": "ocrWeight", "value": "1000", "type": "text" },
            { "key": "image", "type": "file", "src": "", "disabled": true },
            { "key": "pileImage", "type": "file", "src": "", "disabled": true }
          ]
        },
        "url": {
          "raw": "{{baseUrl}}/api/iot-value/weight",
          "host": ["{{baseUrl}}"],
          "path": ["api", "iot-value", "weight"]
        },
        "description": "Kirim BERAT langsung tanpa OCR. Field 'ocrWeight' (kg) WAJIB. 'image' OPSIONAL (aktifkan bila mau lampirkan bukti foto). Mewarisi Bearer {{token}}."
      }
    },
    {
      "name": "6. IoT — Lihat Gambar (Bulog)",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/api/iot/image/1",
          "host": ["{{baseUrl}}"],
          "path": ["api", "iot", "image", "1"]
        },
        "description": "Mewarisi Bearer {{token}}. Ganti '1' dengan harvestId. Login sebagai bulog (request 2, ubah username) agar token role Bulog."
      }
    }
  ]
}
